FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8000 \
    SECOND_BRAIN_ZERO_CHECKPOINT=/data/zero/latest.pt \
    SECOND_BRAIN_ZERO_DEVICE=auto

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
COPY scratch ./scratch
COPY prompts ./prompts
COPY data ./data

RUN python -m pip install --no-cache-dir --upgrade pip \
    && python -m pip install --no-cache-dir . \
    && python -m pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

RUN mkdir -p /app/state /app/runtime /data/zero

EXPOSE 8000

CMD ["sh", "-c", "uvicorn second_brain.web:app --host 0.0.0.0 --port ${PORT}"]
